{
  "_comment": "Trailing garbage from scraped listings. Regex, case-insensitive, anchored at end.",
  "version": 1,
  "patterns": [
    "\\s*[-\\|]\\s*LinkedIn\\s*$",
    "\\s*[-\\|]\\s*Crunchbase\\s*$",
    "\\s*[-\\|]\\s*Glassdoor\\s*$",
    "\\s*[-\\|]\\s*Indeed\\s*$",
    "\\s*[-\\|]\\s*ZoomInfo\\s*$",
    "\\s*[-\\|]\\s*Apollo(?:\\.io)?\\s*$",
    "\\s*[-\\|]\\s*Facebook\\s*$",
    "\\s*[-\\|]\\s*Twitter\\s*$",
    "\\s*[-\\|]\\s*X\\s*$",
    "\\s*[-\\|]\\s*Instagram\\s*$",
    "\\s*[-\\|]\\s*YouTube\\s*$",
    "\\s*[-\\|]\\s*Home\\s*$",
    "\\s*[-\\|]\\s*Homepage\\s*$",
    "\\s*[-\\|]\\s*About\\s*(?:Us)?\\s*$",
    "\\s*[-\\|]\\s*Contact\\s*(?:Us)?\\s*$",
    "\\s*[-\\|]\\s*Official\\s*(?:Site|Website)\\s*$",
    "\\s*[-\\|]\\s*Careers\\s*$",
    "\\s*[-\\|]\\s*Jobs\\s*$",
    "\\s*[-\\|]\\s*Wikipedia\\s*$",
    "\\s*[-\\|]\\s*BBB\\s*(?:Business Profile)?\\s*$",
    "\\s*[-\\|]\\s*Yelp\\s*$",
    "\\s*[-\\|]\\s*BusinessWire\\s*$",
    "\\s*[-\\|]\\s*PRNewswire\\s*$",
    "\\s*\\(Opens?\\s*(?:in|a)\\s*[^)]*\\)\\s*$"
  ]
}
