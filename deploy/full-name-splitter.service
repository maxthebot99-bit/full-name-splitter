# Systemd unit template for full-name-splitter.
#
# /usr/local/bin/app may rewrite this file at deploy time (e.g. to inject
# the auto-assigned $PORT and the WorkingDirectory). The hardening
# directives below are the canonical "post-2026-04-27 lockdown" pattern;
# do not weaken them without updating memory/project_vps_lockdown_complete.md.
#
# Reuses cleaners-hub's already-planted credentials:
#   /etc/credstore.encrypted/xai-api-key      (Grok PAT — required)
#   /etc/credstore.encrypted/resend-api-key   (optional, for completion emails)

[Unit]
Description=full-name-splitter web app (Splits Full Name → First + Last via Grok)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/dashboard/apps/full-name-splitter
Environment=PORT=8201
Environment=CLEANERS_HUB_ENV=prod
Environment=CLEANERS_HUB_DATA_DIR=/var/lib/full-name-splitter
Environment=CLEANERS_HUB_SESSIONS_DIR=/var/tmp/full-name-splitter/sessions
# Credentials are decrypted into /run/credentials/full-name-splitter.service/<name>
# at unit start; we expose them to the app via the env names the Python
# code looks at (XAI_API_KEY_FILE, RESEND_API_KEY_FILE).
LoadCredentialEncrypted=xai-api-key:/etc/credstore.encrypted/xai-api-key
LoadCredentialEncrypted=resend-api-key:/etc/credstore.encrypted/resend-api-key
Environment=XAI_API_KEY_FILE=%d/xai-api-key
Environment=RESEND_API_KEY_FILE=%d/resend-api-key

ExecStart=/var/www/dashboard/apps/full-name-splitter/deploy/start.sh
Restart=on-failure
RestartSec=10
# Stop deadline: SIGTERM, then SIGKILL after this. uvicorn waits for
# in-flight requests to drain, but a long Grok call can hold the worker
# past systemd's default 90s. Shorter window keeps install-vps.sh
# restarts predictable; the run worker's SIGKILL just leaves
# session.contexts as it was on the last batch_cb (persisted to memory),
# which "Continue cleaning" then resumes from cleanly.
TimeoutStopSec=20
KillSignal=SIGTERM
StandardOutput=journal
StandardError=journal
SyslogIdentifier=full-name-splitter

# ─── Hardening ───────────────────────────────────────────────────────
# Mirrors kbot's pattern; tightened for an internet-exposed app.
#
# Three directives were tried initially and removed because they break
# pandas/openpyxl/numpy under CPython:
#   * PrivateDevices=true          (blocks /dev/shm — pandas needs it)
#   * MemoryDenyWriteExecute=true  (blocks W+X mmap that some C exts use)
#   * SystemCallFilter=~@privileged @resources  (blocks prlimit64,
#     setrlimit, sched_setaffinity that numpy uses on import)
# If a future Python upgrade makes them safe again, re-enable here.
#
# ReadWritePaths=/var/tmp/full-name-splitter was also tried and removed: with
# PrivateTmp=true, /var/tmp is the unit's private namespace anyway, so
# whitelisting a subpath there fails namespace setup if the host path
# doesn't exist yet (which it doesn't on first start).
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectClock=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=true
RestrictRealtime=true
LockPersonality=true
SystemCallArchitectures=native
SystemCallFilter=@system-service
# strict ProtectSystem makes /var/lib read-only by default; whitelist the
# dir we actually need to write spend.sqlite3 into. (PrivateTmp covers
# /var/tmp without an explicit ReadWritePaths.)
ReadWritePaths=/var/lib/full-name-splitter
StateDirectory=full-name-splitter
RuntimeDirectory=full-name-splitter

# ─── Egress firewall (SSRF mitigation, 2026-05-14) ──────────────────
# The address-tab fetch_pages() worker accepts user-supplied URLs from
# CSV cells. Without egress restrictions, a malicious CSV with
# website_url=http://169.254.169.254/ or website_url=http://10.x.x.x/
# would reach cloud metadata, the Tailscale mesh, or any sibling app
# on the VPS LAN. Block private IPv4, link-local + metadata, Tailscale
# CGNAT, and IPv6 link-local + ULA. Public-internet egress (xAI,
# OpenRouter, ScrapingBee, Resend, user-supplied public URLs) is
# unaffected. Loopback (127.0.0.0/8, ::1) is intentionally NOT denied
# here so any unit-internal health checks keep working; the residual
# loopback SSRF path is closed by the planned code-level fix in
# fetch.py (private-IP rejection before the HTTP request).
IPAddressDeny=10.0.0.0/8
IPAddressDeny=172.16.0.0/12
IPAddressDeny=192.168.0.0/16
IPAddressDeny=169.254.0.0/16
IPAddressDeny=100.64.0.0/10
IPAddressDeny=fe80::/10
IPAddressDeny=fc00::/7

[Install]
WantedBy=multi-user.target
